# =============================================================================
# LogLens — Environment Configuration
# =============================================================================
# Copy this file to .env and set your values before starting the server.
#
#   cp .env.example .env
#
# Both LOGS_PORTAL_API_KEY and LOGS_PORTAL_SECRET MUST be set to non-default
# values or the server will refuse to start.
# =============================================================================

# --- Authentication (required) ------------------------------------------------
# API key users enter in the browser to log in.
LOGS_PORTAL_API_KEY=your-secure-api-key-here

# HMAC signing secret used for session tokens. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
LOGS_PORTAL_SECRET=change-this-to-a-random-secret

# --- Server -------------------------------------------------------------------
LOGS_PORTAL_HOST=0.0.0.0
LOGS_PORTAL_PORT=8600
LOGS_PORTAL_WORKERS=2

# --- Rate Limiting -----------------------------------------------------------
# Max failed auth attempts per IP before lockout.
LOGS_PORTAL_AUTH_MAX_ATTEMPTS=3
# Lockout window in seconds.
LOGS_PORTAL_AUTH_WINDOW_SECONDS=300

# --- Upload -------------------------------------------------------------------
# Maximum upload size in megabytes.
LOGS_PORTAL_MAX_UPLOAD_MB=50
# Upload chunk size in kilobytes (for multipart uploads).
LOGS_PORTAL_UPLOAD_CHUNK_KB=1024

# --- Session Token ------------------------------------------------------------
# Token time-to-live in seconds (default 1 hour).
LOGS_PORTAL_TOKEN_TTL=3600

# --- Analysis Thresholds (per-request, in seconds) ---------------------------
# Requests slower than this are flagged as "slow".
LOGS_PORTAL_SLOW_THRESHOLD=10.0
# Requests slower than this are flagged as "critical".
LOGS_PORTAL_CRITICAL_THRESHOLD=30.0

# --- Auto-Detection -----------------------------------------------------------
# Number of lines sampled when auto-detecting log type.
LOGS_PORTAL_DETECT_SAMPLE_SIZE=50
